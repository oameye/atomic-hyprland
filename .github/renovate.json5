{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: [
    "config:recommended",
    ":semanticCommitsDisabled",
    ":dependencyDashboard",
  ],
  timezone: "Europe/Brussels",
  schedule: ["before 6am on monday"],
  labels: ["dependencies"],
  packageRules: [
    {
      matchDepNames: [
        "hyprwm/hyprwayland-scanner",
        "hyprwm/hyprutils",
        "hyprwm/hyprlang",
        "hyprwm/hyprcursor",
        "hyprwm/hyprgraphics",
        "hyprwm/aquamarine",
        "hyprwm/hyprwire",
        "hyprwm/hyprland-protocols",
        "hyprwm/hyprtoolkit",
        "hyprwm/hyprland-guiutils",
      ],
      groupName: "hyprwm toolkit chain",
    },
    {
      matchDepNames: [
        "hyprwm/hyprlock",
        "hyprwm/hypridle",
        "hyprwm/hyprpicker",
        "hyprwm/hyprsunset",
        "hyprwm/xdg-desktop-portal-hyprland",
      ],
      groupName: "hyprwm satellite tools",
    },
    {
      matchDepNames: [
        "hyprwm/hyprland-qt-support",
        "hyprwm/hyprpolkitagent",
      ],
      groupName: "hyprwm Qt6 components",
    },
    {
      matchDepNames: [
        "basecamp/omarchy",
      ],
      groupName: "omarchy",
    },
    {
      matchDepNames: [
        "gabm/Satty",
        "Gustash/Hyprshot",
        "sentriz/cliphist",
        "Vladimir-csp/uwsm",
        "Vladimir-csp/xdg-terminal-exec",
        "abenz1267/walker",
        "abenz1267/elephant",
        "tsowell/wiremix",
        "pythops/bluetui",
        "pythops/impala",
        "charmbracelet/gum",
        "starship/starship",
        "WhySoBad/hyprland-preview-share-picker",
        "ryanoasis/nerd-fonts",
      ],
      groupName: "desktop support tools",
    },
  ],
  customManagers: [
    // GitHub-release-tracked tags. Each dep gets its own manager block so
    // the depName is explicit -- no fragile parsing of nearby comments.
    {
      customType: "regex",
      managerFilePatterns: ["/^build_files/(build|source-builds)\\.sh$/"],
      matchStrings: ["HYPRWAYLAND_SCANNER_TAG=\"(?<currentValue>v\\d+\\.\\d+\\.\\d+)\""],
      depNameTemplate: "hyprwm/hyprwayland-scanner",
      datasourceTemplate: "github-releases",
    },
    {
      customType: "regex",
      managerFilePatterns: ["/^build_files/(build|source-builds)\\.sh$/"],
      matchStrings: ["HYPRUTILS_TAG=\"(?<currentValue>v\\d+\\.\\d+\\.\\d+)\""],
      depNameTemplate: "hyprwm/hyprutils",
      datasourceTemplate: "github-releases",
    },
    {
      customType: "regex",
      managerFilePatterns: ["/^build_files/(build|source-builds)\\.sh$/"],
      matchStrings: ["HYPRLANG_TAG=\"(?<currentValue>v\\d+\\.\\d+\\.\\d+)\""],
      depNameTemplate: "hyprwm/hyprlang",
      datasourceTemplate: "github-releases",
    },
    {
      customType: "regex",
      managerFilePatterns: ["/^build_files/(build|source-builds)\\.sh$/"],
      matchStrings: ["HYPRCURSOR_TAG=\"(?<currentValue>v\\d+\\.\\d+\\.\\d+)\""],
      depNameTemplate: "hyprwm/hyprcursor",
      datasourceTemplate: "github-releases",
    },
    {
      customType: "regex",
      managerFilePatterns: ["/^build_files/(build|source-builds)\\.sh$/"],
      matchStrings: ["HYPRGRAPHICS_TAG=\"(?<currentValue>v\\d+\\.\\d+\\.\\d+)\""],
      depNameTemplate: "hyprwm/hyprgraphics",
      datasourceTemplate: "github-releases",
    },
    {
      customType: "regex",
      managerFilePatterns: ["/^build_files/(build|source-builds)\\.sh$/"],
      matchStrings: ["AQUAMARINE_TAG=\"(?<currentValue>v\\d+\\.\\d+\\.\\d+)\""],
      depNameTemplate: "hyprwm/aquamarine",
      datasourceTemplate: "github-releases",
    },
    {
      customType: "regex",
      managerFilePatterns: ["/^build_files/(build|source-builds)\\.sh$/"],
      matchStrings: ["HYPRWIRE_TAG=\"(?<currentValue>v\\d+\\.\\d+\\.\\d+)\""],
      depNameTemplate: "hyprwm/hyprwire",
      datasourceTemplate: "github-releases",
    },
    {
      customType: "regex",
      managerFilePatterns: ["/^build_files/(build|source-builds)\\.sh$/"],
      matchStrings: ["HYPRLAND_PROTOCOLS_TAG=\"(?<currentValue>v\\d+\\.\\d+\\.\\d+)\""],
      depNameTemplate: "hyprwm/hyprland-protocols",
      datasourceTemplate: "github-releases",
    },
    {
      customType: "regex",
      managerFilePatterns: ["/^build_files/(build|source-builds)\\.sh$/"],
      matchStrings: ["GLAZE_TAG=\"(?<currentValue>v\\d+\\.\\d+\\.\\d+)\""],
      depNameTemplate: "stephenberry/glaze",
      datasourceTemplate: "github-releases",
    },
    {
      customType: "regex",
      managerFilePatterns: ["/^build_files/(build|source-builds)\\.sh$/"],
      matchStrings: ["HYPRLAND_TAG=\"(?<currentValue>v\\d+\\.\\d+\\.\\d+)\""],
      depNameTemplate: "hyprwm/Hyprland",
      datasourceTemplate: "github-releases",
    },
    {
      customType: "regex",
      managerFilePatterns: ["/^build_files/(build|source-builds)\\.sh$/"],
      matchStrings: ["HYPRTOOLKIT_TAG=\"(?<currentValue>v\\d+\\.\\d+\\.\\d+)\""],
      depNameTemplate: "hyprwm/hyprtoolkit",
      datasourceTemplate: "github-releases",
    },
    {
      customType: "regex",
      managerFilePatterns: ["/^build_files/(build|source-builds)\\.sh$/"],
      matchStrings: ["HYPR_GUIUTILS_TAG=\"(?<currentValue>v\\d+\\.\\d+\\.\\d+)\""],
      depNameTemplate: "hyprwm/hyprland-guiutils",
      datasourceTemplate: "github-releases",
    },
    {
      customType: "regex",
      managerFilePatterns: ["/^build_files/(build|source-builds)\\.sh$/"],
      matchStrings: ["HYPRLOCK_TAG=\"(?<currentValue>v\\d+\\.\\d+\\.\\d+)\""],
      depNameTemplate: "hyprwm/hyprlock",
      datasourceTemplate: "github-releases",
    },
    {
      customType: "regex",
      managerFilePatterns: ["/^build_files/(build|source-builds)\\.sh$/"],
      matchStrings: ["HYPRIDLE_TAG=\"(?<currentValue>v\\d+\\.\\d+\\.\\d+)\""],
      depNameTemplate: "hyprwm/hypridle",
      datasourceTemplate: "github-releases",
    },
    {
      customType: "regex",
      managerFilePatterns: ["/^build_files/(build|source-builds)\\.sh$/"],
      matchStrings: ["HYPRPICKER_TAG=\"(?<currentValue>v\\d+\\.\\d+\\.\\d+)\""],
      depNameTemplate: "hyprwm/hyprpicker",
      datasourceTemplate: "github-releases",
    },
    {
      customType: "regex",
      managerFilePatterns: ["/^build_files/(build|source-builds)\\.sh$/"],
      matchStrings: ["HYPRSUNSET_TAG=\"(?<currentValue>v\\d+\\.\\d+\\.\\d+)\""],
      depNameTemplate: "hyprwm/hyprsunset",
      datasourceTemplate: "github-releases",
    },
    {
      customType: "regex",
      managerFilePatterns: ["/^build_files/(build|source-builds)\\.sh$/"],
      matchStrings: ["XDP_HYPRLAND_TAG=\"(?<currentValue>v\\d+\\.\\d+\\.\\d+)\""],
      depNameTemplate: "hyprwm/xdg-desktop-portal-hyprland",
      datasourceTemplate: "github-releases",
    },
    {
      customType: "regex",
      managerFilePatterns: ["/^build_files/(build|source-builds)\\.sh$/"],
      matchStrings: ["HYPR_QT_SUPPORT_TAG=\"(?<currentValue>v\\d+\\.\\d+\\.\\d+)\""],
      depNameTemplate: "hyprwm/hyprland-qt-support",
      datasourceTemplate: "github-releases",
    },
    {
      customType: "regex",
      managerFilePatterns: ["/^build_files/(build|source-builds)\\.sh$/"],
      matchStrings: ["HYPR_POLKITAGENT_TAG=\"(?<currentValue>v\\d+\\.\\d+\\.\\d+)\""],
      depNameTemplate: "hyprwm/hyprpolkitagent",
      datasourceTemplate: "github-releases",
    },
    {
      customType: "regex",
      managerFilePatterns: ["/^build_files/(build|source-builds)\\.sh$/"],
      matchStrings: ["OMARCHY_REF=\"(?<currentValue>v\\d+\\.\\d+\\.\\d+)\""],
      depNameTemplate: "basecamp/omarchy",
      datasourceTemplate: "github-releases",
    },
    {
      customType: "regex",
      managerFilePatterns: ["/^build_files/(build|source-builds)\\.sh$/"],
      matchStrings: ["SATTY_TAG=\"(?<currentValue>v\\d+\\.\\d+\\.\\d+)\""],
      depNameTemplate: "gabm/Satty",
      datasourceTemplate: "github-releases",
    },
    {
      customType: "regex",
      managerFilePatterns: ["/^build_files/(build|source-builds)\\.sh$/"],
      matchStrings: ["HYPRSHOT_TAG=\"(?<currentValue>\\d+\\.\\d+\\.\\d+)\""],
      depNameTemplate: "Gustash/Hyprshot",
      datasourceTemplate: "github-releases",
    },
    {
      customType: "regex",
      managerFilePatterns: ["/^build_files/(build|source-builds)\\.sh$/"],
      matchStrings: ["CLIPHIST_TAG=\"(?<currentValue>v\\d+\\.\\d+\\.\\d+)\""],
      depNameTemplate: "sentriz/cliphist",
      datasourceTemplate: "github-releases",
    },
    {
      customType: "regex",
      managerFilePatterns: ["/^build_files/(build|source-builds)\\.sh$/"],
      matchStrings: ["UWSM_TAG=\"(?<currentValue>v\\d+\\.\\d+\\.\\d+)\""],
      depNameTemplate: "Vladimir-csp/uwsm",
      datasourceTemplate: "github-releases",
    },
    {
      customType: "regex",
      managerFilePatterns: ["/^build_files/(build|source-builds)\\.sh$/"],
      matchStrings: ["XDG_TERMINAL_EXEC_TAG=\"(?<currentValue>v\\d+\\.\\d+\\.\\d+)\""],
      depNameTemplate: "Vladimir-csp/xdg-terminal-exec",
      datasourceTemplate: "github-releases",
    },
    {
      customType: "regex",
      managerFilePatterns: ["/^build_files/(build|source-builds)\\.sh$/"],
      matchStrings: ["WALKER_TAG=\"(?<currentValue>v\\d+\\.\\d+\\.\\d+)\""],
      depNameTemplate: "abenz1267/walker",
      datasourceTemplate: "github-releases",
    },
    {
      customType: "regex",
      managerFilePatterns: ["/^build_files/(build|source-builds)\\.sh$/"],
      matchStrings: ["ELEPHANT_TAG=\"(?<currentValue>v\\d+\\.\\d+\\.\\d+)\""],
      depNameTemplate: "abenz1267/elephant",
      datasourceTemplate: "github-releases",
    },
    {
      customType: "regex",
      managerFilePatterns: ["/^build_files/(build|source-builds)\\.sh$/"],
      matchStrings: ["WIREMIX_TAG=\"(?<currentValue>v\\d+\\.\\d+\\.\\d+)\""],
      depNameTemplate: "tsowell/wiremix",
      datasourceTemplate: "github-releases",
    },
    {
      customType: "regex",
      managerFilePatterns: ["/^build_files/(build|source-builds)\\.sh$/"],
      matchStrings: ["BLUETUI_TAG=\"(?<currentValue>v\\d+\\.\\d+\\.\\d+)\""],
      depNameTemplate: "pythops/bluetui",
      datasourceTemplate: "github-releases",
    },
    {
      customType: "regex",
      managerFilePatterns: ["/^build_files/(build|source-builds)\\.sh$/"],
      matchStrings: ["IMPALA_TAG=\"(?<currentValue>v\\d+\\.\\d+\\.\\d+)\""],
      depNameTemplate: "pythops/impala",
      datasourceTemplate: "github-releases",
    },
    {
      customType: "regex",
      managerFilePatterns: ["/^build_files/(build|source-builds)\\.sh$/"],
      matchStrings: ["GUM_TAG=\"(?<currentValue>v\\d+\\.\\d+\\.\\d+)\""],
      depNameTemplate: "charmbracelet/gum",
      datasourceTemplate: "github-releases",
    },
    {
      customType: "regex",
      managerFilePatterns: ["/^build_files/(build|source-builds)\\.sh$/"],
      matchStrings: ["STARSHIP_TAG=\"(?<currentValue>v\\d+\\.\\d+\\.\\d+)\""],
      depNameTemplate: "starship/starship",
      datasourceTemplate: "github-releases",
    },
    {
      customType: "regex",
      managerFilePatterns: ["/^build_files/(build|source-builds)\\.sh$/"],
      matchStrings: ["HYPRLAND_PREVIEW_SHARE_PICKER_TAG=\"(?<currentValue>v\\d+\\.\\d+\\.\\d+)\""],
      depNameTemplate: "WhySoBad/hyprland-preview-share-picker",
      datasourceTemplate: "github-releases",
    },
    {
      customType: "regex",
      managerFilePatterns: ["/^build_files/(build|source-builds)\\.sh$/"],
      matchStrings: ["NERD_FONTS_TAG=\"(?<currentValue>v\\d+\\.\\d+\\.\\d+)\""],
      depNameTemplate: "ryanoasis/nerd-fonts",
      datasourceTemplate: "github-releases",
    },
  ],
}
