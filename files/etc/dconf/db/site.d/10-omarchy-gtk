# GTK / GNOME defaults matching omarchy's rice.
# omarchy-theme-set-gnome mirrors this at runtime by flipping color-scheme
# between prefer-dark/prefer-light and setting icon-theme from the active
# theme's icons.theme file; these values are the "baseline" so GTK apps
# render coherently on first boot before any theme switch happens.

[org/gnome/desktop/interface]
color-scheme='prefer-dark'
gtk-theme='Adwaita-dark'
icon-theme='Papirus-Dark'
cursor-theme='Adwaita'
font-name='Inter 10'
document-font-name='Inter 10'
monospace-font-name='JetBrainsMono Nerd Font 10'
