#!/usr/bin/env bash

# Add wheel members to docker/incus-admin/libvirt groups on first boot.
# Group creation itself is handled declaratively by
# /usr/lib/sysusers.d/atomic-hyprland.conf; this script only touches
# group *membership*.
#
# Derived from ublue-os/bluefin bluefin-dx-groups.

set -euo pipefail

GROUP_SETUP_VER=2
GROUP_SETUP_VER_FILE="/etc/atomic-hyprland/dx-groups-version"
GROUP_SETUP_VER_RAN=$(cat "$GROUP_SETUP_VER_FILE" 2>/dev/null || echo "")

mkdir -p /etc/atomic-hyprland

if [[ -f $GROUP_SETUP_VER_FILE && "$GROUP_SETUP_VER" = "$GROUP_SETUP_VER_RAN" ]]; then
  echo "Group setup already run. Exiting."
  exit 0
fi

# Ensure the groups exist (belt-and-braces: sysusers.d should have done it).
for g in docker incus-admin libvirt; do
  getent group "$g" >/dev/null || groupadd --system "$g"
done

readarray -t wheelarray < <(getent group wheel | cut -d ':' -f 4 | tr ',' '\n' | sed '/^$/d')
for user in "${wheelarray[@]}"; do
  usermod -aG docker "$user"
  usermod -aG incus-admin "$user"
  usermod -aG libvirt "$user"
done

echo "$GROUP_SETUP_VER" >"$GROUP_SETUP_VER_FILE"
