#!/usr/bin/env bash

set -euo pipefail

PREINSTALL_DIR="/usr/share/flatpak/preinstall.d"
STATE_DIR="/var/lib/atomic-hyprland"
STAMP_FILE="${STATE_DIR}/flatpak-preinstall.sha256"

manifest_hash() {
    find "$PREINSTALL_DIR" -maxdepth 1 -type f -name '*.preinstall' -print \
        | LC_ALL=C sort \
        | while IFS= read -r preinstall_file; do
            sha256sum "$preinstall_file"
        done \
        | sha256sum \
        | awk '{print $1}'
}

current_hash="$(manifest_hash)"
previous_hash="$(cat "$STAMP_FILE" 2>/dev/null || true)"

if [[ "$current_hash" == "$previous_hash" ]]; then
    echo "Flatpak preinstall manifest unchanged. Exiting."
    exit 0
fi

install_manifest() {
    local manifest="$1"
    local app_id branch remote

    app_id="$(sed -n 's/^\[Flatpak Preinstall \(.*\)\]$/\1/p' "$manifest" | head -n1)"
    branch="$(sed -n 's/^Branch=//p' "$manifest" | head -n1)"
    remote="$(sed -n 's/^Remote=//p' "$manifest" | head -n1)"

    [[ -n "$app_id" ]] || {
        echo "Failed to parse app ID from $manifest" >&2
        exit 1
    }

    branch="${branch:-stable}"
    remote="${remote:-flathub}"

    if flatpak info --system "${app_id}//${branch}" >/dev/null 2>&1; then
        echo "${app_id}//${branch} already installed. Skipping."
        return
    fi

    flatpak install --system --noninteractive -y "$remote" "${app_id}//${branch}"
}

while IFS= read -r manifest; do
    install_manifest "$manifest"
done < <(find "$PREINSTALL_DIR" -maxdepth 1 -type f -name '*.preinstall' | LC_ALL=C sort)

install -d "$STATE_DIR"
printf '%s\n' "$current_hash" > "$STAMP_FILE"
