#!/usr/bin/env bash
# Shim so `chromium` on PATH invokes the Flatpak build.
# omarchy-launch-webapp, omarchy-theme-set-browser, and any manual invocation
# call the binary by bare name; this keeps their code paths working without
# patching each script.
#
# --user-data-dir redirects Flatpak chromium's config from its sandbox path
# (~/.var/app/org.chromium.Chromium/config/chromium/) to the standard
# ~/.config/chromium/ so omarchy's flags/config live where its scripts expect.
# Theme color is delivered separately through /etc/chromium/policies/managed,
# exposed to the sandbox via a matching flatpak override in build.sh.
# Any later --user-data-dir= argument in "$@" wins, so callers can override.
exec flatpak run org.chromium.Chromium \
    --user-data-dir="$HOME/.config/chromium" \
    "$@"
